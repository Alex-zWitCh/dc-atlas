APP_ENV=production
APP_DATA_DIR=/var/lib/dc-atlas
APP_DB_PATH=/var/lib/dc-atlas/dc_atlas.sqlite3
APP_LOG_DIR=/var/log/dc-atlas

BOT_DISPLAY_NAME=DC Atlas
BOT_LANGUAGE=ru

POLL_INTERVAL_SECONDS=300
POLL_MAX_SOURCES_PER_CYCLE=100
POLL_HTTP_TIMEOUT_SECONDS=15

TELEGRAM_PUBLIC_BASE_URL=https://t.me/s
TELEGRAM_MAX_PHOTOS_PER_POST=3
TELEGRAM_FETCH_MEDIA=false
TELEGRAM_TEMP_MEDIA_DIR=/tmp/dc-atlas-media
TELEGRAM_STORE_MEDIA_BINARY=false
TELEGRAM_STORE_FULL_TEXT=true
TELEGRAM_POST_RETENTION_DAYS=30
TELEGRAM_POST_RETENTION_MAX_PER_SOURCE=500

# Опциональный HTTP-прокси для обхода блокировок Telegram
# TELEGRAM_PROXY_ENABLED=true
# TELEGRAM_PROXY_URL=http://user:pass@proxy.example.com:1080

CATALOG_AUTO_APPROVE=true
REPORTS_TO_HIDE=5

DELTA_CHAT_PROFILE_PATH=/var/lib/dc-atlas/deltachat-profile

# Delta Chat account credentials
# DC_EMAIL=bot@example.org
# DC_PASSWORD=your_password

# Optional custom IMAP/SMTP servers (defaults to chatmail domain)
# DC_IMAP_SERVER=mail.example.org
# DC_SMTP_SERVER=mail.example.org

# Admin users (comma-separated email addresses)
# BOT_ADMIN_EMAILS=admin@example.com,other@example.com

# Telegram error policy: how many consecutive errors before disabling source
# TELEGRAM_MAX_CONSECUTIVE_ERRORS=5

# Support contact shown in help/welcome messages (Delta Chat invite link)
# Leave empty to hide support line
# SUPPORT_INVITE_URL=https://i.delta.chat/#...

# Avatar settings
# AVATAR_FETCH_ENABLED=true
# AVATAR_MAX_BYTES=1048576
# AVATAR_HTTP_TIMEOUT_SECONDS=10
# AVATAR_CACHE_DIR=/var/lib/dc-atlas/avatars
# AVATAR_REFRESH_INTERVAL_HOURS=24
# AVATAR_ALLOWED_MIME=image/jpeg,image/png,image/webp
# BOT_AVATAR_PATH=/var/lib/dc-atlas/avatars/defaults/bot.png

# Delta Chat local profile cleanup
# DC_PROFILE_CLEANUP_ENABLED=true
# DC_PROFILE_CLEANUP_DAYS=7
# DC_PROFILE_CLEANUP_INTERVAL_SECONDS=3600
